// function of the the C program represents the dealers turn in the Black Jack card gmae in which will be dispalyed in the output
void Deal(struct Card deck[52], int money, int bet, int c) {
    struct Card playerHand[5] = { {' ', ' '}, {' ', ' '}, {' ', ' '}, {' ', ' '}, {' ', ' '} };
    int playerSum = 0; //sum of points of hand
    struct Card dealerHand[5] = { {' ', ' '}, {' ', ' '}, {' ', ' '}, {' ', ' '}, {' ', ' '} };
    int dealerSum = 0;
    printf("\nYour money: $%d\nYour bet: $%d\n", money, bet);
    bet = BetAsk(bet, money);
    money -= bet;
    int e; //rand index value used for shuffling
    if (c > 42) { //shuffling
        printf("Shuffling...\n\n");
        struct Card shuffleDeck[52] = { {' ', ' '} };
        for (int d = 0; d < 52; ++d) {// for each card in the deck, try and put it in the shuffle deck randomly and then, at the end, set the deck to the shuffle deck
            e = rand() % 52;
            while (shuffleDeck[e].value != 0) { //if the space is not empty,
                e = rand() % 52;//try another space
            }
            shuffleDeck[e] = deck[d];
        }
        deck = shuffleDeck;
        c = 0;
    }
    dealerHand[0] = deck[c++];
    dealerHand[1] = deck[c++];
    dealerSum += dealerHand[0].value + dealerHand[1].value;
    printf("The dealer shows: one flipped card, ");
    GetFace(dealerHand[1]);
    //todo: have player have their turn
    playerHand[0] = deck[c++];
    playerHand[1] = deck[c++];
    playerSum += playerHand[0].value + playerHand[1].value;
    printf("\nYou have: ");
    GetFace(playerHand[0]);
    printf(", ");
    GetFace(playerHand[1]);
    printf("; %d", playerSum);
    if (playerSum <= 21) {
        char choice;
        printf("\nHit or stand? Enter H or S: ");
        scanf_s(" %c", &choice); //space before %c clears new line character from scanf_s statement in BetAsk
        if ((choice == 'H') || (choice == 'h')) {
            printf("You drew: ");
            playerHand[2] = deck[c++];
            playerSum += playerHand[2].value;
            GetFace(playerHand[2]);
        }
    }
    printf("\n");
    for (int a = 2; a < 4; ++a) {
        if (dealerSum < 16) {
            dealerHand[a] = deck[(a + c)]; //add cards to the dealer's hand until he reaches 16, where he must stand
            printf("Dealer draws ");
            GetFace(dealerHand[a]);
            printf("\n");
            dealerSum += dealerHand[a].value;
        }
        break; //stand by breaking the loop if the dealer reaches 
    }

    //win/loss logic
    printf("\nDealer's hidden card was ");// This message lets the user know that the dealers card has been flipped
    GetFace(dealerHand[0]);
    printf("\nYour total is %d.\n", playerSum);
    printf("Dealer's total is %d.\n", dealerSum);
    if ((playerSum > 21) && (dealerSum > 21)) {
        printf("You and the dealer both lost, you get back your $%d.", bet);
        money += bet;
    }
    else if (playerSum > 21) {
        printf("Bust! You lost $%d", bet);
    }
    else if ((playerSum < dealerSum) && (dealerSum <= 21)) {
        if (dealerSum <= 21) {
            printf("\nDealer won! You lost $%d", bet);// This line of the C program lets the user know the the dealer won and the other player has lost
        }
        else {
            printf("You win $%d!", bet * 2);// This printf statment send a message to the user that they have won
            money += bet * 2;
        }
    }
    else if (playerSum > dealerSum) {
        if (playerSum == 21) {
            printf("Natural! You win $%d!!", bet * 3); //this message appears when they get a natural, which is exactly 21
            money += bet * 3;
        }
        else {
            printf("You win $%d!", bet * 2);// This printf statment send a message to the user that they have won
            money += bet * 2;
        }
    }
    else {
        printf("Bust! You lost $%d", bet); //if none of these winning conditions are met, bust

    }
    if (money > 1000000) {
        printf("You won Blackjack by winning a million dollars! Congratulations!");// The printf statments in this C program lets the user know that they have won the game
    }
    else if (money <= 0) {
        printf("You went bankrupt! You lost!");
    }
    else {
        Deal(deck, money, bet, c);
    }
}


// This fuction asks the asks the user to place their bets
int BetAsk(int bet, int money) {
    char choice;
    printf("\nWould you like to change your bet? Y or N? Enter Q to quit: ");// this line of the C program will ask the user if they want to change their bets. The message provided in this C program will be displayed in the output.
    scanf_s(" %c", &choice); //space before %c to clear new line character from previous scanf_s statement
    if ((choice == 'Y') || (choice == 'y')) {
        printf("\nInput your bet: ");// This line of the C program code prompts the user to place their bet
        scanf_s("%d", &bet);
        if (bet > money) {
            printf("You can't bet more than you have!\n");// This line of the C program sends an error message letting the user know that they cannot bet more cards than they have
            BetAsk(bet, money);
        }
        else {
            return(bet);
        }
    }
    else if ((choice == 'Q') || (choice == 'q')) {
        exit(0); //exit the program using exit from stdlib with status 0
    }
    return(bet);
}

