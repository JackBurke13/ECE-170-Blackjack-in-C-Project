//The struct for cards that allows it to store its face, suit and value
struct Card {
    char face;
    char suit;
    int value;
};

//Prints the name of cards (like ace of spades) given the face and suit value of the cards
void GetFace(struct Card card) { //has to be a pointer because simply returning a string is not allowed
    switch (card.face) {
    case 'a':
        printf("Ace");
        break;
    case 'k':
        printf("King");
        break;
    case 'q':
        printf("Queen");
        break;
    case 'j':
        printf("Jack");
        break;
    case '0':
        printf("10");
        break;
    case ' ':
        printf("Blank");
        break;
    default:
        printf("%c", card.face);
    }
    printf(" of ");
    switch (card.suit) {
    case 'c':
        printf("Clubs");
        break;
    case's':
        printf("Spades");
        break;
    case'h':
        printf("Hearts");
        break;
    case'd':
        printf("Diamonds");
        break;
    default:
        printf("Invalid");
    }
}

//The primary function that redurses with each round
//Handles the player's and dealer's hand of cards,
//Shuffling cards,
//Having the player make their turn,
//The dealer drawing cards,
//And win/loss conditions
void Deal(struct Card deck[52], int money, int bet, int c) {
    struct Card playerHand[5] = { {' ', ' '}, {' ', ' '}, {' ', ' '}, {' ', ' '}, {' ', ' '} };
    int playerSum = 0; //sum of points of hand
    struct Card dealerHand[5] = { {' ', ' '}, {' ', ' '}, {' ', ' '}, {' ', ' '}, {' ', ' '} };
    int dealerSum = 0;
    printf("\nYour money: $%d\nYour bet: $%d\n", money, bet);
    bet = BetAsk(bet, money);
    money -= bet;
    int e; //rand index value used for shuffling
    if (c > 42) { //shuffling
        printf("Shuffling...\n\n");
        struct Card shuffleDeck[52] = { {' ', ' '} };
        for (int d = 0; d < 52; ++d) {// for each card in the deck, try and put it in the shuffle deck randomly and then, at the end, set the deck to the shuffle deck
            e = rand() % 52;
            while (shuffleDeck[e].value != 0) { //if the space is not empty,
                e = rand() % 52;//try another space
            }
            shuffleDeck[e] = deck[d];
        }
        deck = shuffleDeck;
        c = 0;
    }
    dealerHand[0] = deck[c++];
    dealerHand[1] = deck[c++];
    dealerSum += dealerHand[0].value + dealerHand[1].value;
    printf("The dealer shows: one flipped card, ");
    GetFace(dealerHand[1]);
    //todo: have player have their turn
    playerHand[0] = deck[c++];
    playerHand[1] = deck[c++];
    playerSum += playerHand[0].value + playerHand[1].value;
    printf("\nYou have: ");
    GetFace(playerHand[0]);
    printf(", ");
    GetFace(playerHand[1]);
    printf("; %d", playerSum);
    if (playerSum <= 21) {
        char choice;
        printf("\nHit or stand? Enter H or S: ");
        scanf_s(" %c", &choice); //space before %c clears new line character from scanf_s statement in BetAsk
        if ((choice == 'H') || (choice == 'h')) {
            printf("You drew: ");
            playerHand[2] = deck[c++];
            playerSum += playerHand[2].value;
            GetFace(playerHand[2]);
        }
    }
    printf("\n");
    for (int a = 2; a < 4; ++a) {
        if (dealerSum < 16) {
            dealerHand[a] = deck[(a + c)]; //add cards to the dealer's hand until he reaches 16, where he must stand
            printf("Dealer draws ");
            GetFace(dealerHand[a]);
            printf("\n");
            dealerSum += dealerHand[a].value;
        }
        break; //stand by breaking the loop if the dealer reaches 
    }
    //win/loss logic
    printf("\nDealer's flipped card was ");
    GetFace(dealerHand[0]);
    printf("\nYour total is %d.\n", playerSum);
    printf("Dealer's total is %d.\n", dealerSum);
    if ((playerSum > 21) && (dealerSum > 21)) {
        printf("You and the dealer both lost, you get back your $%d.", bet);
        money += bet;
    }
    else if (playerSum > 21) {
        printf("Bust! You lost $%d", bet);
    }
    else if ((playerSum < dealerSum) && (dealerSum <= 21)) {
        if (dealerSum <= 21) {
            printf("\nDealer won! You lost $%d", bet);
        }
        else {
            printf("You win $%d!", bet * 2);
            money += bet * 2;
        }
    }
    else if (playerSum > dealerSum) {
        if (playerSum == 21) {
            printf("Natural! You win $%d!!", bet * 3);
            money += bet * 3;
        }
        else {
            printf("You win $%d!", bet * 2);
            money += bet * 2;
        }
    }
    else {
        printf("Bust! You lost $%d", bet); //if none of these winning conditions are met, bust

    }
    if (money > 1000000) {
        printf("You won Blackjack by winning a million dollars! Congratulations!");
    }
    else {
        Deal(deck, money, bet, c);
    }
}

//The BetAsk function asks the user if they want to change their bet each round
//It makes sure the user doesnt try to bet more than they have and calls the function again if they do
int BetAsk(int bet, int money) {
    char choice;
    printf("\nWould you like to change your bet? Y or N?: ");
    scanf_s(" %c", &choice); //space before %c to clear new line character from previous scanf_s statement
    if ((choice == 'Y') || (choice == 'y')) {
        printf("\nInput your bet: ");
        scanf_s("%d", &bet);
        if (bet > money) {
            printf("You can't bet more than you have!\n");
            BetAsk(bet, money);
        }
        else {
            return(bet);
        }
    }
    return(bet);
}

