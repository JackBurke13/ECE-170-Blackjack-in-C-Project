struct Card {
    char face;
    char suit;
    int value;
};

int GetValue(struct Card card) {
    switch (card.face) {
    case 'a':
        return 11;
        break;
    case 'k':
    case 'q': //if it's a face card or ten return 10
    case 'j':
    case '0':
        return 10;
        break;
    case ' ': //so we can use this function to see if a card isn't there, since cards in hands start as 2 space characters
        return 0;
        break;
    default:
        return (int)card.face; //if it's not an ace or face card, return the value as an integer
    }
}
